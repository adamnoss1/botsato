# ===========================
# TELEGRAM BOT
# ===========================
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username

# Admin Telegram IDs (comma separated)
ADMIN_TELEGRAM_IDS=123456789,987654321

# Support/Notification Channel
SUPPORT_CHANNEL_ID=-100xxxxxxxxxx
NOTIFICATION_CHANNEL_ID=-100xxxxxxxxxx

# Channel subscription verification
REQUIRED_CHANNEL_ID=-100xxxxxxxxxx
REQUIRED_CHANNEL_USERNAME=your_channel_username

# ===========================
# DATABASE
# ===========================
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===========================
# SESSION
# ===========================
SESSION_SECRET=your_very_long_random_secret_key_here_min_32_chars

# ===========================
# ADMIN PANEL
# ===========================
ADMIN_PASSWORD=your_secure_admin_password
ADMIN_USERNAME=admin

# ===========================
# SATOFILL API
# ===========================
SATOFILL_API_KEY=your_satofill_api_key_here
SATOFILL_API_URL=https://satofill.com/api

# ===========================
# APP CONFIG
# ===========================
PORT=3000
NODE_ENV=production
APP_URL=https://your-app.railway.app

# ===========================
# EXCHANGE RATE & PRICING
# ===========================
EXCHANGE_RATE=3.75
PROFIT_MARGIN=0.20

# ===========================
# BACKUP
# ===========================
BACKUP_DIR=./backups