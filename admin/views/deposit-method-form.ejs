<%
const isEdit  = method !== null;
const pageBody = `
<div style="margin-bottom:16px;">
  <a href="/admin/deposit-methods" class="btn btn-outline btn-sm">
    <i class="bi bi-arrow-right"></i> رجوع
  </a>
</div>
<div class="card" style="max-width:600px;">
  <div class="card-header">${isEdit ? '✏️ تعديل طريقة إيداع' : '➕ إضافة طريقة إيداع'}</div>
  <div class="card-body">
    <form action="${isEdit ? '/admin/deposit-methods/'+method.id : '/admin/deposit-methods'}" method="POST">
      <input type="hidden" name="_csrf" value="${csrfToken}">
      <div class="form-group">
        <label class="form-label">الاسم *</label>
        <input type="text" name="name" class="form-control" required
               value="${isEdit ? method.name : ''}">
      </div>
      <div class="form-group">
        <label class="form-label">الاسم بالعربي</label>
        <input type="text" name="nameAr" class="form-control"
               value="${isEdit && method.nameAr ? method.nameAr : ''}">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
        <div class="form-group">
          <label class="form-label">سعر الصرف *</label>
          <input type="number" step="0.000001" name="exchangeRate" class="form-control" required
                 value="${isEdit ? method.exchangeRate : '3.75'}">
        </div>
        <div class="form-group">
          <label class="form-label">الحد الأدنى *</label>
          <input type="number" step="0.01" name="minAmount" class="form-control" required
                 value="${isEdit ? method.minAmount : '10'}">
        </div>
        <div class="form-group">
          <label class="form-label">الحد الأقصى *</label>
          <input type="number" step="0.01" name="maxAmount" class="form-control" required
                 value="${isEdit ? method.maxAmount : '10000'}">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">الوصف</label>
        <input type="text" name="description" class="form-control"
               value="${isEdit && method.description ? method.description : ''}">
      </div>
      <div class="form-group">
        <label class="form-label">تعليمات الإيداع</label>
        <textarea name="instructions" class="form-control" rows="4"
                  placeholder="رقم الحساب، عنوان المحفظة...">${isEdit && method.instructions ? method.instructions : ''}</textarea>
      </div>
      <button type="submit" class="btn btn-primary">
        <i class="bi bi-floppy"></i> ${isEdit ? 'حفظ' : 'إضافة'}
      </button>
    </form>
  </div>
</div>
`;
%>
<%- include('layout', { body: pageBody }) %>