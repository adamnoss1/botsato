<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>لوحة التحكم</title>
  <link rel="stylesheet" href="/public/css/admin.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
<%- include('partials/sidebar') %>
<div class="main-content">
  <%- include('partials/topbar', { title: 'لوحة التحكم' }) %>
  <main class="page-content">
    <%- include('partials/alerts') %>

    <!-- STATS -->
    <div class="stats-grid">
      <div class="stat-card">
        <div>
          <div class="stat-value"><%= totalUsers %></div>
          <div class="stat-label">إجمالي المستخدمين</div>
          <small style="color:#10b981;">+<%= todayUsers %> اليوم</small>
        </div>
        <div class="stat-icon">👥</div>
      </div>
      <div class="stat-card">
        <div>
          <div class="stat-value"><%= totalOrders %></div>
          <div class="stat-label">إجمالي الطلبات</div>
          <small style="color:#10b981;">+<%= todayOrders %> اليوم</small>
        </div>
        <div class="stat-icon">📦</div>
      </div>
      <div class="stat-card">
        <div>
          <div class="stat-value" style="color:#f59e0b;"><%= pendingDeposits %></div>
          <div class="stat-label">إيداعات معلقة</div>
        </div>
        <div class="stat-icon">💰</div>
      </div>
      <div class="stat-card">
        <div>
          <div class="stat-value" style="color:#ef4444;"><%= pendingManualOrders %></div>
          <div class="stat-label">طلبات يدوية معلقة</div>
        </div>
        <div class="stat-icon">⚙️</div>
      </div>
      <div class="stat-card">
        <div>
          <div class="stat-value" style="color:#3b82f6;"><%= processingOrders %></div>
          <div class="stat-label">طلبات قيد التنفيذ</div>
        </div>
        <div class="stat-icon">🔄</div>
      </div>
      <div class="stat-card">
        <div>
          <div class="stat-value" style="color:#10b981;"><%= totalRevenue %>$</div>
          <div class="stat-label">إجمالي الإيرادات</div>
        </div>
        <div class="stat-icon">💵</div>
      </div>
    </div>

    <!-- TABLES -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">

      <!-- Latest Orders -->
      <div class="card">
        <div class="card-header" style="display:flex;justify-content:space-between;">
          <span>📦 آخر الطلبات</span>
          <a href="/admin/orders" class="btn btn-sm btn-outline">عرض الكل</a>
        </div>
        <div class="table-responsive">
          <table>
            <thead>
              <tr>
                <th>#</th><th>المستخدم</th><th>الخدمة</th><th>الإجمالي</th><th>الحالة</th>
              </tr>
            </thead>
            <tbody>
              <% latestOrders.forEach(function(o) { %>
              <tr>
                <td><%= o.id %></td>
                <td><%= o.user ? o.user.firstName : '—' %></td>
                <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                  <%= o.product ? o.product.name : '—' %>
                </td>
                <td><%= parseFloat(o.totalPrice).toFixed(2) %>$</td>
                <td>
                  <span class="badge
                    <% if (o.status === 'COMPLETED') { %>badge-success
                    <% } else if (o.status === 'PROCESSING') { %>badge-info
                    <% } else if (o.status === 'FAILED' || o.status === 'CANCELLED') { %>badge-danger
                    <% } else { %>badge-warning<% } %>">
                    <%= o.status %>
                  </span>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Latest Deposits -->
      <div class="card">
        <div class="card-header" style="display:flex;justify-content:space-between;">
          <span>💰 آخر الإيداعات</span>
          <a href="/admin/deposits" class="btn btn-sm btn-outline">عرض الكل</a>
        </div>
        <div class="table-responsive">
          <table>
            <thead>
              <tr>
                <th>#</th><th>المستخدم</th><th>المبلغ</th><th>الطريقة</th><th>الحالة</th>
              </tr>
            </thead>
            <tbody>
              <% latestDeposits.forEach(function(d) { %>
              <tr>
                <td><%= d.id %></td>
                <td><%= d.user ? d.user.firstName : '—' %></td>
                <td><%= parseFloat(d.amountUsd).toFixed(2) %>$</td>
                <td><%= d.method ? d.method.name : '—' %></td>
                <td>
                  <span class="badge
                    <% if (d.status === 'APPROVED') { %>badge-success
                    <% } else if (d.status === 'REJECTED') { %>badge-danger
                    <% } else { %>badge-warning<% } %>">
                    <%= d.status %>
                  </span>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</div>
</body>
</html>