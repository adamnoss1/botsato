<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>لوحة التحكم</title>
  <link rel="stylesheet" href="/public/css/admin.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
<%- include('partials/sidebar') %>
<div class="main-content">
  <%- include('partials/topbar', { title: 'لوحة التحكم' }) %>
  <main class="page-content">
    <%- include('partials/alerts') %>

    <!-- إحصائيات سريعة -->
    <div class="stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr));">

      <div class="stat-card">
        <div>
          <div class="stat-value"><%= totalUsers %></div>
          <div class="stat-label">إجمالي المستخدمين</div>
          <small style="color:#10b981;">+<%= todayUsers %> اليوم</small>
        </div>
        <div class="stat-icon">👥</div>
      </div>

      <div class="stat-card">
        <div>
          <div class="stat-value"><%= totalOrders %></div>
          <div class="stat-label">إجمالي الطلبات</div>
          <small style="color:#10b981;">+<%= todayOrders %> اليوم</small>
        </div>
        <div class="stat-icon">📦</div>
      </div>

      <div class="stat-card">
        <div>
          <div class="stat-value" style="color:#f59e0b;"><%= pendingDeposits %></div>
          <div class="stat-label">إيداعات معلقة</div>
        </div>
        <div class="stat-icon">⏳</div>
      </div>

      <div class="stat-card">
        <div>
          <div class="stat-value" style="color:#ef4444;"><%= pendingManualOrders %></div>
          <div class="stat-label">طلبات يدوية معلقة</div>
        </div>
        <div class="stat-icon">⚙️</div>
      </div>

      <div class="stat-card">
        <div>
          <div class="stat-value" style="color:#3b82f6;"><%= processingOrders %></div>
          <div class="stat-label">طلبات قيد التنفيذ</div>
        </div>
        <div class="stat-icon">🔄</div>
      </div>

      <div class="stat-card">
        <div>
          <div class="stat-value" style="color:#10b981;"><%= netBalanceUsd %>$</div>
          <div class="stat-label">صافي الرصيد في النظام</div>
          <small style="color:#6b7280;">إيداعات - سحوبات - عمولات</small>
        </div>
        <div class="stat-icon">🏦</div>
      </div>

    </div>

    <!-- إحصائيات الأرباح -->
    <h3 style="font-size:0.95rem;font-weight:700;margin:20px 0 12px;color:#4f46e5;">
      💹 إحصائيات الإيرادات والأرباح
      <small style="font-weight:400;color:#6b7280;font-size:0.8rem;">
        (هامش الربح: <%= profitMarginPct %>%)
      </small>
    </h3>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-bottom:24px;">

      <!-- اليوم -->
      <div class="card" style="border-right:4px solid #4f46e5;">
        <div class="card-body">
          <div style="font-size:0.8rem;color:#6b7280;margin-bottom:8px;">📅 اليوم</div>
          <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
            <span style="font-size:0.85rem;">الإيرادات:</span>
            <strong style="color:#3b82f6;"><%= todayRevenueUsd %>$</strong>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="font-size:0.85rem;">الأرباح المقدرة:</span>
            <strong style="color:#10b981;"><%= todayProfitUsd %>$</strong>
          </div>
          <div style="margin-top:8px;padding-top:8px;border-top:1px solid #f1f5f9;font-size:0.8rem;color:#6b7280;">
            إيداعات: <%= todayDepositsCount %> (<%= todayDepositsUsd %>$)
          </div>
        </div>
      </div>

      <!-- الشهر الحالي -->
      <div class="card" style="border-right:4px solid #10b981;">
        <div class="card-body">
          <div style="font-size:0.8rem;color:#6b7280;margin-bottom:8px;">
            📆 هذا الشهر
            <% if (monthGrowth !== null) { %>
              <span style="color:<%= parseFloat(monthGrowth) >= 0 ? '#10b981' : '#ef4444' %>;margin-right:8px;">
                <%= parseFloat(monthGrowth) >= 0 ? '▲' : '▼' %> <%= Math.abs(parseFloat(monthGrowth)) %>%
              </span>
            <% } %>
          </div>
          <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
            <span style="font-size:0.85rem;">الإيرادات:</span>
            <strong style="color:#3b82f6;"><%= monthRevenueUsd %>$</strong>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="font-size:0.85rem;">الأرباح المقدرة:</span>
            <strong style="color:#10b981;"><%= monthProfitUsd %>$</strong>
          </div>
          <div style="margin-top:8px;padding-top:8px;border-top:1px solid #f1f5f9;font-size:0.8rem;color:#6b7280;">
            إيداعات: <%= monthDepositsCount %> (<%= monthDepositsUsd %>$) |
            سحوبات: <%= monthWithdrawCount %> (<%= monthWithdrawUsd %>$)
          </div>
        </div>
      </div>

      <!-- الشهر الماضي -->
      <div class="card" style="border-right:4px solid #6b7280;">
        <div class="card-body">
          <div style="font-size:0.8rem;color:#6b7280;margin-bottom:8px;">📊 الشهر الماضي</div>
          <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
            <span style="font-size:0.85rem;">الإيرادات:</span>
            <strong style="color:#3b82f6;"><%= lastMonthRevUsd %>$</strong>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="font-size:0.85rem;">الأرباح المقدرة:</span>
            <strong style="color:#10b981;"><%= lastMonthProfUsd %>$</strong>
          </div>
        </div>
      </div>

      <!-- الإجمالي الكلي -->
      <div class="card" style="border-right:4px solid #f59e0b;">
        <div class="card-body">
          <div style="font-size:0.8rem;color:#6b7280;margin-bottom:8px;">📈 الإجمالي الكلي</div>
          <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
            <span style="font-size:0.85rem;">إجمالي الإيرادات:</span>
            <strong style="color:#3b82f6;"><%= totalRevenueUsd %>$</strong>
          </div>
          <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
            <span style="font-size:0.85rem;">إجمالي الأرباح:</span>
            <strong style="color:#10b981;"><%= totalProfitUsd %>$</strong>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="font-size:0.85rem;">أرباح المكتملة:</span>
            <strong style="color:#10b981;"><%= completedProfUsd %>$</strong>
          </div>
        </div>
      </div>

    </div>

    <!-- الإيداعات والسحوبات والعمولات -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;">

      <div class="card">
        <div class="card-header" style="background:#f0fdf4;">💰 الإيداعات المقبولة</div>
        <div class="card-body">
          <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
            <span style="color:#6b7280;font-size:0.85rem;">الإجمالي:</span>
            <strong style="color:#10b981;font-size:1.1rem;"><%= totalDepositsUsd %>$</strong>
          </div>
          <div style="display:flex;justify-content:space-between;margin-bottom:4px;font-size:0.8rem;">
            <span style="color:#6b7280;">عدد المعاملات:</span>
            <span><%= totalDepositsCount %></span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:0.8rem;">
            <span style="color:#6b7280;">هذا الشهر:</span>
            <span style="color:#10b981;"><%= monthDepositsUsd %>$</span>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header" style="background:#fff7ed;">💸 السحوبات المكتملة</div>
        <div class="card-body">
          <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
            <span style="color:#6b7280;font-size:0.85rem;">الإجمالي:</span>
            <strong style="color:#f59e0b;font-size:1.1rem;"><%= totalWithdrawUsd %>$</strong>
          </div>
          <div style="display:flex;justify-content:space-between;margin-bottom:4px;font-size:0.8rem;">
            <span style="color:#6b7280;">عدد المعاملات:</span>
            <span><%= totalWithdrawCount %></span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:0.8rem;">
            <span style="color:#6b7280;">هذا الشهر:</span>
            <span style="color:#f59e0b;"><%= monthWithdrawUsd %>$</span>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header" style="background:#fdf4ff;">👥 عمولات الإحالة</div>
        <div class="card-body">
          <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
            <span style="color:#6b7280;font-size:0.85rem;">الإجمالي:</span>
            <strong style="color:#a855f7;font-size:1.1rem;"><%= totalCommUsd %>$</strong>
          </div>
          <div style="display:flex;justify-content:space-between;margin-bottom:4px;font-size:0.8rem;">
            <span style="color:#6b7280;">عدد العمليات:</span>
            <span><%= totalCommCount %></span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:0.8rem;">
            <span style="color:#6b7280;">هذا الشهر:</span>
            <span style="color:#a855f7;"><%= monthCommUsd %>$</span>
          </div>
        </div>
      </div>

    </div>

    <!-- الجداول -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

      <!-- أحدث الطلبات -->
      <div class="card">
        <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
          <span>📦 آخر الطلبات</span>
          <a href="/admin/orders" class="btn btn-sm btn-outline">عرض الكل</a>
        </div>
        <div class="table-responsive">
          <table>
            <thead>
              <tr>
                <th>#</th><th>المستخدم</th><th>الخدمة</th>
                <th>الإجمالي</th><th>الحالة</th>
              </tr>
            </thead>
            <tbody>
              <% latestOrders.forEach(function(o) { %>
              <tr>
                <td><%= o.id %></td>
                <td><%= o.user ? o.user.firstName : '—' %></td>
                <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                  <%= o.product ? o.product.name : '—' %>
                </td>
                <td><%= parseFloat(o.totalPrice).toFixed(2) %>$</td>
                <td>
                  <% var sc = o.status; %>
                  <span class="badge <%=
                    sc==='COMPLETED' ? 'badge-success' :
                    sc==='PROCESSING' ? 'badge-info' :
                    (sc==='FAILED'||sc==='CANCELLED') ? 'badge-danger' : 'badge-warning'
                  %>"><%= sc %></span>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- أحدث الإيداعات -->
      <div class="card">
        <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
          <span>💰 آخر الإيداعات</span>
          <a href="/admin/deposits" class="btn btn-sm btn-outline">عرض الكل</a>
        </div>
        <div class="table-responsive">
          <table>
            <thead>
              <tr>
                <th>#</th><th>المستخدم</th><th>المبلغ</th>
                <th>الطريقة</th><th>الحالة</th>
              </tr>
            </thead>
            <tbody>
              <% latestDeposits.forEach(function(d) { %>
              <tr>
                <td><%= d.id %></td>
                <td><%= d.user ? d.user.firstName : '—' %></td>
                <td><strong><%= parseFloat(d.amountUsd).toFixed(2) %>$</strong></td>
                <td><%= d.method ? d.method.name : '—' %></td>
                <td>
                  <% var ds = d.status; %>
                  <span class="badge <%=
                    ds==='APPROVED' ? 'badge-success' :
                    ds==='REJECTED' ? 'badge-danger' : 'badge-warning'
                  %>">
                    <%= ds==='PENDING' ? 'معلق' : ds==='APPROVED' ? 'مقبول' : 'مرفوض' %>
                  </span>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- أفضل المنتجات -->
    <div class="card">
      <div class="card-header">🏆 أفضل الخدمات مبيعاً</div>
      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>#</th><th>الخدمة</th><th>عدد الطلبات</th>
              <th>إجمالي الإيرادات</th><th>الأرباح المقدرة</th>
            </tr>
          </thead>
          <tbody>
            <%
              var pMargin = parseFloat(profitMarginPct) / 100;
              var pRatio  = pMargin / (1 + pMargin);
              var medals  = ['🥇','🥈','🥉','4.','5.'];
            %>
            <% topProducts.forEach(function(t, i) { %>
            <%
              var tRev   = parseFloat(t._sum && t._sum.totalPrice ? t._sum.totalPrice : 0);
              var tProf  = tRev * pRatio;
              var tCount = t._count ? t._count.id : 0;
            %>
            <tr>
              <td><span style="font-size:1.1rem;"><%= medals[i] || (i+1)+'.' %></span></td>
              <td><strong><%= t.product ? t.product.name : 'غير معروف' %></strong></td>
              <td><span class="badge badge-info"><%= tCount %></span></td>
              <td style="color:#3b82f6;font-weight:600;"><%= tRev.toFixed(2) %>$</td>
              <td style="color:#10b981;font-weight:600;">~<%= tProf.toFixed(2) %>$</td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </main>
</div>
</body>
</html>