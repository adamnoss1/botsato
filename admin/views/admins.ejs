<%
const pageBody = `
<div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;">

  <div class="card">
    <div class="card-header">👥 قائمة المديرين</div>
    <div class="table-responsive">
      <table>
        <thead>
          <tr><th>#</th><th>اسم المستخدم</th><th>Telegram ID</th><th>النوع</th><th>الحالة</th><th>آخر دخول</th><th>إجراء</th></tr>
        </thead>
        <tbody>
          ${admins.map(a => `
          <tr>
            <td>${a.id}</td>
            <td><strong>${a.username}</strong></td>
            <td><code>${a.telegramId || '—'}</code></td>
            <td><span class="badge ${a.isSuperAdmin ? 'badge-gold' : 'badge-info'}">
              ${a.isSuperAdmin ? 'سوبر أدمن' : 'أدمن'}
            </span></td>
            <td><span class="badge ${a.isActive ? 'badge-success' : 'badge-danger'}">
              ${a.isActive ? 'نشط' : 'معطل'}
            </span></td>
            <td style="font-size:0.8rem;">${a.lastLoginAt ? new Date(a.lastLoginAt).toLocaleString('ar') : '—'}</td>
            <td>
              <div style="display:flex;gap:4px;">
                <form action="/admin/admins/${a.id}/toggle" method="POST">
                  <input type="hidden" name="_csrf" value="${csrfToken}">
                  <button class="btn btn-sm ${a.isActive ? 'btn-warning' : 'btn-success'}">
                    ${a.isActive ? 'تعطيل' : 'تفعيل'}
                  </button>
                </form>
                ${a.id !== admin.id ? `
                <form action="/admin/admins/${a.id}/delete" method="POST">
                  <input type="hidden" name="_csrf" value="${csrfToken}">
                  <button class="btn btn-sm btn-danger" onclick="return confirm('حذف المدير؟')">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>` : ''}
              </div>
            </td>
          </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-header">➕ إضافة مدير</div>
    <div class="card-body">
      <form action="/admin/admins" method="POST">
        <input type="hidden" name="_csrf" value="${csrfToken}">
        <div class="form-group">
          <label class="form-label">اسم المستخدم</label>
          <input type="text" name="username" class="form-control" required>
        </div>
        <div class="form-group">
          <label class="form-label">كلمة المرور</label>
          <input type="password" name="password" class="form-control" required minlength="8">
        </div>
        <div class="form-group">
          <label class="form-label">Telegram ID (اختياري)</label>
          <input type="text" name="telegramId" class="form-control">
        </div>
        <div class="form-group" style="display:flex;align-items:center;gap:10px;">
          <input type="checkbox" name="isSuperAdmin" id="isSuperAdmin" style="width:18px;height:18px;">
          <label for="isSuperAdmin">سوبر أدمن</label>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
          <i class="bi bi-person-plus"></i> إضافة
        </button>
      </form>
    </div>
  </div>

</div>
`;
%>
<%- include('layout', { body: pageBody }) %>